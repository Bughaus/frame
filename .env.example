# App environment
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Backend Server
PORT=3000

# Database
POSTGRES_USER=vereinapp
POSTGRES_PASSWORD=vereinapp_secret
POSTGRES_DB=vereinapp
DATABASE_URL=postgresql://vereinapp:vereinapp_secret@localhost:5432/vereinapp?schema=public

# JWT Auth
JWT_SECRET=super_secret_jwt_key_please_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# File Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=20
