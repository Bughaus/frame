# Site Configuration (SSL/Caddy)
DOMAIN_NAME=clubhouse.your-club-domain.com
ACME_EMAIL=admin@your-club-domain.com

# Deployment Image Tags (Must match GHCR repository)
BACKEND_IMAGE=ghcr.io/bughaus/frame-backend:latest
FRONTEND_IMAGE=ghcr.io/bughaus/frame-frontend:latest

# App environment
NODE_ENV=production
FRONTEND_URL=https://${DOMAIN_NAME}

# Backend Server
PORT=3000

# Database
POSTGRES_USER=vereinapp
POSTGRES_PASSWORD=change_this_to_a_secure_db_password
POSTGRES_DB=vereinapp
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# JWT Auth
JWT_SECRET=super_secret_jwt_key_please_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# File Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=20

# Initial Admin Setup (Deployment Bootstrap)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change_this_to_a_secure_password
INITIAL_ADMIN_EMAIL=admin@your-club-domain.com

# Member Management
DEFAULT_MEMBER_PASSWORD=change_this_standard_password
